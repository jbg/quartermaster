{
  "name": "@quartermaster/web",
  "version": "1.7.2",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "vite dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:api": "openapi-ts",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "clean:build": "rm -rf build .svelte-kit/output",
    "build": "pnpm clean:build && vite build",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "qrcode": "1.5.4",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.58.0",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "svelte": "5.55.5",
    "vite": "8.0.10"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.97.0",
    "@types/qrcode": "1.5.6",
    "@types/node": "25.6.0",
    "svelte-check": "4.4.6",
    "typescript": "6.0.3",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "3.5.1",
    "@playwright/test": "1.59.1",
    "vitest": "4.1.5"
  },
  "volta": {
    "node": "25.9.0"
  }
}
