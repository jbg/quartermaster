default_platform(:ios)

require "json"

def appstore_private_key
  ENV.fetch("APPSTORE_API_PRIVATE_KEY").gsub("\\n", "\n")
end

def truthy?(value)
  %w[1 true yes].include?(value.to_s.downcase)
end

platform :ios do
  private_lane :appstore_api_key do
    app_store_connect_api_key(
      key_id: ENV.fetch("APPSTORE_API_KEY_ID"),
      issuer_id: ENV.fetch("APPSTORE_ISSUER_ID"),
      key_content: appstore_private_key,
      is_key_content_base64: false
    )
  end

  desc "Run App Store metadata checks without uploading a binary"
  lane :check_metadata do
    precheck(
      api_key: appstore_api_key,
      app_identifier: ENV.fetch("QUARTERMASTER_IOS_BUNDLE_ID"),
      default_rule_level: "warn"
    )
  end

  desc "Upload App Store listing metadata without submitting for review"
  lane :upload_metadata do
    deliver(
      api_key: appstore_api_key,
      app_identifier: ENV.fetch("QUARTERMASTER_IOS_BUNDLE_ID"),
      metadata_path: "fastlane/metadata",
      screenshots_path: "fastlane/screenshots",
      skip_binary_upload: true,
      skip_screenshots: true,
      submit_for_review: false,
      run_precheck_before_submit: false,
      force: true
    )
  end

  desc "Review or upload App Store privacy details"
  lane :privacy_details do |options|
    json_path = options[:json_path] || "fastlane/app_privacy_details.json"
    details = JSON.parse(File.read(json_path))
    UI.message("Loaded #{details.length} App Privacy detail entries from #{json_path}")

    upload = options.key?(:upload) ? truthy?(options[:upload]) : truthy?(ENV["QM_IOS_UPLOAD_PRIVACY_DETAILS"])
    unless upload
      UI.message("Skipping App Store Connect upload. Pass upload:true or set QM_IOS_UPLOAD_PRIVACY_DETAILS=true to upload.")
      next
    end

    upload_app_privacy_details_to_app_store(
      username: ENV.fetch("APPSTORE_USERNAME"),
      team_id: ENV["APPSTORE_TEAM_ID"],
      team_name: ENV["APPSTORE_TEAM_NAME"],
      app_identifier: ENV.fetch("QUARTERMASTER_IOS_BUNDLE_ID"),
      json_path: json_path,
      skip_publish: !truthy?(options[:publish])
    )
  end

  desc "Upload an exported IPA to TestFlight"
  lane :upload_testflight do |options|
    ipa_path = options[:ipa_path] || ENV.fetch("QM_IOS_IPA_PATH")
    pilot(
      api_key: appstore_api_key,
      app_identifier: ENV.fetch("QUARTERMASTER_IOS_BUNDLE_ID"),
      ipa: ipa_path,
      changelog: ENV["PILOT_CHANGELOG"],
      skip_waiting_for_build_processing: true
    )
  end
end
