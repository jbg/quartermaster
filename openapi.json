  "components": {
    "schemas": {
      "ApiErrorBody": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Stable error code, machine-readable."
          },
          "message": {
            "type": "string",
            "description": "Human-readable description. Not localised; clients should prefer `code`."
          }
        }
      },
      "BarcodeLookupResponse": {
        "type": "object",
        "required": [
          "product",
          "source"
        ],
        "properties": {
          "product": {
            "$ref": "#/components/schemas/ProductDto"
          },
          "source": {
            "type": "string",
            "description": "`cache` when served from our DB, `openfoodfacts` when fetched just now."
          }
        }
      },
      "ConsumeRequest": {
        "type": "object",
        "required": [
          "product_id",
          "quantity",
          "unit"
        ],
        "properties": {
          "location_id": {
            "type": [
              "string",
              "null"
            ],
            "format": "uuid"
          },
          "product_id": {
            "type": "string",
            "format": "uuid"
          },
          "quantity": {
            "type": "string"
          },
          "unit": {
            "type": "string"
          }
        }
      },
      "ConsumeResponse": {
        "type": "object",
        "required": [
          "consumed"
        ],
        "properties": {
          "consumed": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ConsumedBatchDto"
            }
          }
        }
      },
      "ConsumedBatchDto": {
        "type": "object",
        "required": [
          "batch_id",
          "quantity",
          "unit",
          "depleted"
        ],
        "properties": {
          "batch_id": {
            "type": "string",
            "format": "uuid"
          },
          "depleted": {
            "type": "boolean"
          },
          "quantity": {
            "type": "string"
          },
          "unit": {
            "type": "string"
          }
        }
      },
      "CreateProductRequest": {
        "type": "object",
        "required": [
          "name",
          "family"
        ],
        "properties": {
          "barcode": {
            "type": [
              "string",
              "null"
            ]
          },
          "brand": {
            "type": [
              "string",
              "null"
            ]
          },
          "family": {
            "type": "string",
            "description": "One of `mass`, `volume`, `count`."
          },
          "name": {
            "type": "string"
          },
          "preferred_unit": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional display unit override. Must belong to `family`. Defaults to\nthe family's base unit (`g` / `ml` / `piece`) when omitted."
          }
        }
      },
      "CreateStockRequest": {
        "type": "object",
        "required": [
          "product_id",
          "location_id",
          "quantity",
          "unit"
        ],
        "properties": {
          "expires_on": {
            "type": [
              "string",
              "null"
            ]
          },
          "location_id": {
            "type": "string",
            "format": "uuid"
          },
          "note": {
            "type": [
              "string",
              "null"
            ]
          },
          "opened_on": {
            "type": [
              "string",
              "null"
            ]
          },
          "product_id": {
            "type": "string",
            "format": "uuid"
          },
          "quantity": {
            "type": "string"
          },
          "unit": {
            "type": "string"
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string"
          }
        }
      },
      "HouseholdDto": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "LocationDto": {
        "type": "object",
        "required": [
          "id",
          "name",
          "kind",
          "sort_order"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "kind": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "sort_order": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": [
          "username",
          "password"
        ],
        "properties": {
          "device_label": {
            "type": [
              "string",
              "null"
            ]
          },
          "password": {
            "type": "string"
          },
          "username": {
            "type": "string"
          }
        }
      },
      "MeResponse": {
        "type": "object",
        "required": [
          "user"
        ],
        "properties": {
          "household": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/HouseholdDto"
              }
            ]
          },
          "user": {
            "$ref": "#/components/schemas/UserDto"
          }
        }
      },
      "ProductDto": {
        "type": "object",
        "required": [
          "id",
          "name",
          "family",
          "preferred_unit",
          "source"
        ],
        "properties": {
          "barcode": {
            "type": [
              "string",
              "null"
            ]
          },
          "brand": {
            "type": [
              "string",
              "null"
            ]
          },
          "family": {
            "type": "string"
          },
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "image_url": {
            "type": [
              "string",
              "null"
            ]
          },
          "name": {
            "type": "string"
          },
          "preferred_unit": {
            "type": "string"
          },
          "source": {
            "type": "string"
          }
        }
      },
      "ProductSearchResponse": {
        "type": "object",
        "required": [
          "items"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProductDto"
            }
          }
        }
      },
      "RefreshRequest": {
        "type": "object",
        "required": [
          "refresh_token"
        ],
        "properties": {
          "refresh_token": {
            "type": "string"
          }
        }
