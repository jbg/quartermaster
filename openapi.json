              "format": "uuid"
            }
          },
          {
            "name": "expiring_before",
            "in": "query",
            "description": "ISO-8601 date (YYYY-MM-DD). When set, only batches expiring strictly\nbefore this date are returned. Undated batches are excluded.",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          {
            "name": "include_depleted",
            "in": "query",
            "description": "When true, also include batches that have been fully consumed\n(`depleted_at IS NOT NULL`).",
            "required": false,
            "schema": {
              "type": [
                "boolean",
                "null"
              ]
            }
          }
        ],
        "responses": {
          "200": {
